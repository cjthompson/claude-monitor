{
  "description": "All five event types already have an unrelated hook — claude-monitor hooks merged into the same group (same matcher = same group per Claude Code schema)",
  "initial_settings": {
    "hooks": {
      "PermissionRequest": [
        {"hooks": [{"type": "command", "command": "/other/tool", "timeout": 10}]}
      ],
      "Notification": [
        {"matcher": "permission_prompt|idle_prompt", "hooks": [{"type": "command", "command": "/other/tool", "timeout": 10}]}
      ],
      "SubagentStart": [
        {"hooks": [{"type": "command", "command": "/other/tool", "timeout": 10}]}
      ],
      "SubagentStop": [
        {"hooks": [{"type": "command", "command": "/other/tool", "timeout": 10}]}
      ],
      "PostToolUse": [
        {"matcher": "AskUserQuestion", "hooks": [{"type": "command", "command": "/other/tool", "timeout": 10}]}
      ]
    }
  },
  "user_inputs": ["y"],
  "expected": {
    "hooks": {
      "PermissionRequest": [
        {"hooks": [
          {"type": "command", "command": "/other/tool", "timeout": 10},
          {"type": "command", "command": "/new/venv/bin/claude-monitor-hook", "timeout": 300}
        ]}
      ],
      "Notification": [
        {"matcher": "permission_prompt|idle_prompt", "hooks": [
          {"type": "command", "command": "/other/tool", "timeout": 10},
          {"type": "command", "command": "/new/venv/bin/claude-monitor-hook", "timeout": 5}
        ]}
      ],
      "SubagentStart": [
        {"hooks": [
          {"type": "command", "command": "/other/tool", "timeout": 10},
          {"type": "command", "command": "/new/venv/bin/claude-monitor-hook", "timeout": 5}
        ]}
      ],
      "SubagentStop": [
        {"hooks": [
          {"type": "command", "command": "/other/tool", "timeout": 10},
          {"type": "command", "command": "/new/venv/bin/claude-monitor-hook", "timeout": 5}
        ]}
      ],
      "PostToolUse": [
        {"matcher": "AskUserQuestion", "hooks": [
          {"type": "command", "command": "/other/tool", "timeout": 10},
          {"type": "command", "command": "/new/venv/bin/claude-monitor-hook", "timeout": 5}
        ]}
      ]
    }
  }
}
