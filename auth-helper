#!/usr/bin/env bash
# Thin launcher for the claude-monitor-credentials CLI. Resolves the repo root
# from this script's own location (following symlinks) rather than via git, so
# it works whether the repo was cloned or unpacked from a downloaded zip/artifact
# — and whether auth-helper is run in place or symlinked onto PATH.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO_ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

ENTRY="$REPO_ROOT/.venv/bin/claude-monitor-credentials"
if [ ! -x "$ENTRY" ]; then
    echo "Error: $ENTRY not found." >&2
    echo "Install the entry point first: cd \"$REPO_ROOT\" && .venv/bin/pip install -e ." >&2
    exit 1
fi

exec "$ENTRY" "$@"
